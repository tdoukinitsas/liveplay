{
  "name": "liveplay-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "LivePlay — open-source audio playback for live sound operators. Monorepo root: client (Vue/Electron) + server (C++ audio engine).",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Thomas Doukinitsas",
    "email": "creativityfilms@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tdoukinitsas/liveplay.git"
  },
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "node scripts/ensure-server.js && npm run dev --workspace=client",
    "dev:client": "npm run dev --workspace=client",
    "build": "node scripts/build-all.js",
    "build:clean": "node scripts/build-clean.js",
    "build:nuxt": "npm run build --workspace=client",
    "build:client": "npm run build --workspace=client",
    "build:client:electron": "npm run build:electron --workspace=client",
    "build:electron": "npm run server:build && node scripts/build-server-app-mac.js && npm run build:client:electron",
    "install:client": "npm install --workspace=client",
    "server:configure": "cmake --preset vs2022 -S server",
    "server:build": "node scripts/build-server.js",
    "server:run": "node scripts/run-server.js",
    "dev:all": "concurrently -n server,client -c blue,green \"npm:server:run\" \"npm:dev:client\"",
    "version": "node scripts/version.js",
    "bump": "node scripts/version.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
