{
  "name": "e-liveplay",
  "version": "1.4.6",
  "description": "Enhanced LivePlay - Audio cue playback application for live events",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:nuxt\" \"npm run dev:electron\"",
    "dev:nuxt": "nuxt dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "cross-env NODE_ENV=production nuxt generate",
    "build:electron": "cross-env NODE_ENV=production nuxt generate && electron-builder",
    "electron:build": "electron-builder",
    "generate": "cross-env NODE_ENV=production nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "audio",
    "cue",
    "playback",
    "live"
  ],
  "author": {
    "name": "Thomas Doukinitsas",
    "email": "creativityfilms@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@types/node": "^20.10.5",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "nuxt": "^4.0.0",
    "sass": "^1.69.5",
    "typescript": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "archiver": "^7.0.1",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "howler": "^2.2.4",
    "material-symbols": "^0.39.1",
    "uuid": "^9.0.1",
    "wavesurfer.js": "^7.5.0",
    "youtube-search-api": "^2.0.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "build": {
    "appId": "com.liveplay.app",
    "productName": "E-LivePlay",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".output/**/*",
      "electron/**/*",
      "assets/**/*",
      "locales/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "liveplay",
        "name": "LivePlay Project",
        "description": "LivePlay Project File",
        "role": "Editor",
        "icon": "app/assets/icons/4092w/liveplay-document@4092px.png"
      },
      {
        "ext": "lpa",
        "name": "LivePlay Archive",
        "description": "LivePlay Project Archive",
        "role": "Editor",
        "icon": "app/assets/icons/4092w/liveplay-archive@4092.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Stevesibilia",
      "repo": "liveplay"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/assets/icons/4092w/app_icon_darkmode@4092px.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "app/assets/icons/4092w/app_icon_darkmode@4092px.png",
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/assets/icons/4092w/app_icon_darkmode@4092px.png",
      "category": "AudioVideo"
    }
  }
}
