{
  // Nuxt 4 generates per-context tsconfigs into node_modules/.cache/nuxt/.nuxt.
  // This root config just references them so the editor and `vue-tsc` resolve
  // each context (app / server / shared / node) correctly.
  "files": [],
  "references": [
    { "path": "./node_modules/.cache/nuxt/.nuxt/tsconfig.app.json" },
    { "path": "./node_modules/.cache/nuxt/.nuxt/tsconfig.server.json" },
    { "path": "./node_modules/.cache/nuxt/.nuxt/tsconfig.shared.json" },
    { "path": "./node_modules/.cache/nuxt/.nuxt/tsconfig.node.json" }
  ]
}
