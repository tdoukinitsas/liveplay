{
  "name": "liveplay",
  "version": "2.0.7",
  "description": "Audio cue playback application for live events",
  "homepage": "https://github.com/tdoukinitsas/liveplay",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:nuxt\" \"npm run dev:electron\"",
    "dev:nuxt": "nuxt dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "cross-env NODE_ENV=production nuxt generate",
    "build:electron": "cross-env NODE_ENV=production nuxt generate && electron-builder",
    "electron:build": "electron-builder",
    "generate": "cross-env NODE_ENV=production nuxt generate",
    "preview": "nuxt preview"
  },
  "keywords": [
    "electron",
    "audio",
    "cue",
    "playback",
    "live"
  ],
  "author": {
    "name": "Thomas Doukinitsas",
    "email": "creativityfilms@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@nuxt/types": "^2.17.3",
    "@types/node": "^20.10.5",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "28.0.0",
    "electron-builder": "^24.9.1",
    "nuxt": "~3.20.0",
    "sass": "^1.69.5",
    "typescript": "^5.3.3",
    "vue": "^3.4.3",
    "vue-router": "^4.2.5",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "archiver": "^7.0.1",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "material-symbols": "^0.39.1",
    "uuid": "^9.0.1",
    "youtube-search-api": "^2.0.1",
    "yt-dlp-wrap": "^2.3.12"
  },
  "build": {
    "appId": "com.liveplay.app",
    "productName": "LivePlay",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      ".output/**/*",
      "electron/**/*",
      "assets/**/*",
      "locales/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffprobe-installer/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "liveplay",
        "name": "LivePlay Project",
        "description": "LivePlay Project File",
        "role": "Editor",
        "icon": "assets/icons/4092w/liveplay-document@4092px.png"
      },
      {
        "ext": "lpa",
        "name": "LivePlay Archive",
        "description": "LivePlay Project Archive",
        "role": "Editor",
        "icon": "assets/icons/4092w/liveplay-archive@4092.png"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "tdoukinitsas",
      "repo": "liveplay"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/4092w/app_icon_darkmode@4092px.png",
      "publisherName": "Thomas Doukinitsas",
      "extraResources": [
        {
          "from": "../server/build/Release/liveplay-server.exe",
          "to": "server-bin/liveplay-server.exe"
        },
        {
          "from": "../server/build/Release/tag.dll",
          "to": "server-bin/tag.dll"
        },
        {
          "from": "../server/build/Release/z.dll",
          "to": "server-bin/z.dll"
        },
        {
          "from": "../server/build/Release/miniz.dll",
          "to": "server-bin/miniz.dll"
        }
      ]
    },
    "nsis": {
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/4092w/app_icon_darkmode@4092px.png",
      "category": "public.app-category.music",
      "extraResources": [
        {
          "from": "../server/build/liveplay-server",
          "to": "server-bin/liveplay-server"
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 150,
          "y": 220,
          "type": "file"
        },
        {
          "x": 390,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 560,
          "y": 220,
          "type": "file",
          "path": "../server/build/LivePlay Server.app"
        }
      ],
      "window": {
        "width": 700,
        "height": 400
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/4092w/app_icon_darkmode@4092px.png",
      "category": "AudioVideo",
      "extraResources": [
        {
          "from": "../server/build/liveplay-server",
          "to": "server-bin/liveplay-server"
        }
      ]
    }
  }
}
